.destroy-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.anim-stage {
  width: 480rpx;
  height: 480rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.status-text {
  margin-top: 80rpx;
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.75);
  text-align: center;
  max-width: 560rpx;
}

/* ---- Shredder ---- */
.anim-shredder {
  position: relative;
  width: 100%;
  height: 100%;
}
.paper {
  position: absolute;
  top: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 280rpx;
  height: 360rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  transition: transform 2.6s cubic-bezier(0.5, 0.1, 0.5, 1), opacity 0.4s ease 2s;
}
.paper.processing {
  transform: translateX(-50%) translateY(120rpx) scaleY(0.02);
}
.paper.done { opacity: 0; }
.shredder-body {
  position: absolute;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 400rpx;
  height: 100rpx;
  background: #1a1a1a;
  border: 2rpx solid rgba(255,255,255,0.2);
  border-radius: 16rpx;
}

/* ---- Fire ---- */
.anim-fire .flame {
  font-size: 300rpx;
  filter: drop-shadow(0 0 40rpx rgba(255, 80, 0, 0.8));
  transition: all 2.4s ease;
}
.anim-fire .flame.processing {
  transform: scale(1.4);
  filter: drop-shadow(0 0 80rpx rgba(255, 120, 0, 1));
}
.anim-fire .flame.done {
  transform: scale(0.2);
  opacity: 0;
}

/* ---- Black hole ---- */
.anim-hole {
  position: relative;
  width: 100%;
  height: 100%;
}
.hole {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%) scale(0.6);
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #222 0%, #000 60%, transparent 100%);
  box-shadow: 0 0 120rpx rgba(100, 50, 200, 0.4);
  transition: transform 2.4s ease;
}
.hole.processing { transform: translate(-50%, -50%) scale(1.4) rotate(720deg); }
.hole.done { transform: translate(-50%, -50%) scale(0) rotate(1080deg); }

.hole-core {
  position: absolute;
  top: 50%; left: 50%;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #000;
  transform: translate(-50%, -50%);
  transition: all 2.4s ease;
}
.hole-core.done { transform: translate(-50%, -50%) scale(0); }

/* ---- Garbage truck ---- */
.anim-truck .truck {
  font-size: 200rpx;
  transform: translateX(-700rpx);
  transition: transform 2.6s ease;
}
.anim-truck .truck.processing { transform: translateX(0); }
.anim-truck .truck.done { transform: translateX(700rpx); }

/* ---- Keyword egg overlay ----
   Sits below the status text. Hidden until 'done' stage so it lands as a
   reveal, not a spoiler. The slight upward translation gives it a "popping
   in" feeling that matches the medium haptic at the same moment. */
.egg-caption {
  margin-top: 40rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  background-color: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 59, 48, 0.4);
  border-radius: 48rpx;
  opacity: 0;
  transform: translateY(20rpx);
  transition: opacity 400ms ease 200ms, transform 400ms ease 200ms;
  max-width: 560rpx;
}
.egg-caption.show {
  opacity: 1;
  transform: translateY(0);
}
.egg-emoji {
  font-size: 36rpx;
  line-height: 1;
}
.egg-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.92);
  font-weight: 500;
}
