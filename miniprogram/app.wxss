/* ============================================================================
   Global styles — dark theme
   ============================================================================ */

page {
  background-color: #0a0a0a;
  color: #ffffff;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 32rpx;
  line-height: 1.5;
  min-height: 100vh;
}

/* Layout helpers */
.container {
  padding: 48rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.gap-16 { gap: 16rpx; }
.gap-24 { gap: 24rpx; }
.gap-32 { gap: 32rpx; }

/* Typography */
.title { font-size: 56rpx; font-weight: 700; line-height: 1.3; }
.subtitle { font-size: 36rpx; font-weight: 600; line-height: 1.4; }
.body { font-size: 30rpx; color: rgba(255, 255, 255, 0.85); }
.caption { font-size: 24rpx; color: rgba(255, 255, 255, 0.5); }
.muted { color: rgba(255, 255, 255, 0.5); }

/* Cards */
.card {
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  padding: 32rpx;
}

/* Buttons */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  padding: 0 32rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}
.btn::after { border: none; }

.btn-primary {
  background-color: #ff3b30;
  color: #fff;
}
.btn-primary[disabled] {
  background-color: rgba(255, 59, 48, 0.4);
  color: rgba(255, 255, 255, 0.6);
}

.btn-secondary {
  background-color: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.btn-ghost {
  background-color: transparent;
  color: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

/* Tag / Chip — sized for fingers, not pixels */
.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 16rpx 36rpx;
  border-radius: 40rpx;
  background-color: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.85);
  font-size: 30rpx;
  margin: 6rpx;
  transition: background-color 120ms ease, border-color 120ms ease, transform 120ms ease;
}
.chip.active {
  background-color: #ff3b30;
  border-color: #ff3b30;
  color: #fff;
}
/* Press feedback — hover-class on the wxml node hooks into this */
.chip-hover {
  transform: scale(0.94);
  background-color: rgba(255, 255, 255, 0.16);
}
.chip.active.chip-hover {
  background-color: #e02d23;
}

/* Inputs */
.textarea {
  width: 100%;
  min-height: 400rpx;
  padding: 32rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  color: #fff;
  font-size: 32rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

/* Animation keyframes */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.fade-in { animation: fadeIn 400ms ease-out; }

/* Utility */
.full-width { width: 100%; }
.text-center { text-align: center; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mt-48 { margin-top: 48rpx; }
.mt-64 { margin-top: 64rpx; }
.mb-32 { margin-bottom: 32rpx; }
