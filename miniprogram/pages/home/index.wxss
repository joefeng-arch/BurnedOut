.home {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  /* Respect notch/dynamic island */
  padding-top: calc(env(safe-area-inset-top, 0) + 80rpx);
  padding-bottom: calc(env(safe-area-inset-bottom, 0) + 40rpx);
}

.top {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.bottom {
  display: flex;
  flex-direction: column;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.app-brand {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
  /* Drop letter-spacing/uppercase — they're no-ops for Chinese and made it
     look like a stray label. Keeps a calm but readable brand tag. */
}

.hero-q {
  font-size: 72rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
  letter-spacing: -1rpx;
}

/* Daily phrase — date-deterministic micro-copy under the hero question.
   Italic + dimmed so it reads as commentary, not as a CTA. */
.daily-phrase {
  margin-top: 16rpx;
  font-size: 26rpx;
  font-style: italic;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.5;
  letter-spacing: 0.5rpx;
}

/* Logo block — fills the dead space between hero and actions.
   Slight bias upward (justify-content: flex-start with top padding) so the
   logo feels anchored to the question, not floating in the middle. */
.logo-wrap {
  flex: 1;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 40rpx;
  min-height: 440rpx;
}

/* Frame wraps the image and clips it. The image inside is intentionally
   oversized (110%) and shifted up-left by 5% so the white margins of the
   source PNG fall outside the visible area and get cut. */
.logo-frame {
  width: 440rpx;
  height: 440rpx;
  border-radius: 72rpx;
  overflow: hidden;
  position: relative;
  background-color: #3fb892; /* fallback while image loads */
  box-shadow:
    0 0 100rpx rgba(76, 200, 180, 0.22),
    0 24rpx 48rpx rgba(0, 0, 0, 0.4);
  animation: logoFloat 4s ease-in-out infinite;
}

.logo-img {
  position: absolute;
  top: -5%;
  left: -5%;
  width: 110%;
  height: 110%;
}

@keyframes logoFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.actions {
  display: flex;
  flex-direction: column;
}

.secondary-link {
  text-align: center;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.55);
  font-size: 26rpx;
  padding: 16rpx;
}

.footer-note {
  margin-top: 60rpx;
  text-align: center;
}

.lang-switch {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
  gap: 16rpx;
  font-size: 26rpx;
}

.lang {
  color: rgba(255, 255, 255, 0.4);
  padding: 8rpx 12rpx;
}
.lang.active {
  color: #fff;
  font-weight: 600;
}
.lang-sep { color: rgba(255, 255, 255, 0.2); }

.btn-hover { opacity: 0.85; }
