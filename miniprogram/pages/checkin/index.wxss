.checkin-page {
  display: flex;
  flex-direction: column;
  padding-top: 100rpx;
  padding-bottom: 60rpx;
  min-height: 100vh;
}

.title-row { margin-bottom: 56rpx; }

.locked-banner {
  background-color: rgba(76, 217, 100, 0.12);
  border: 2rpx solid rgba(76, 217, 100, 0.3);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.locked {
  opacity: 0.55;
  pointer-events: none;
}

.level-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 48rpx;
}

.level-card {
  flex: 1 1 calc(33.33% - 20rpx);
  min-width: 180rpx;
  padding: 40rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  border: 2rpx solid transparent;
  transition: all 180ms ease;
}

.level-card.active {
  background-color: rgba(255, 59, 48, 0.15);
  border-color: #ff3b30;
}

.level-emoji { font-size: 64rpx; line-height: 1; }
.level-label { font-size: 26rpx; color: rgba(255, 255, 255, 0.85); text-align: center; }

.emotion-section { margin-bottom: 48rpx; }

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.cta-stack {
  margin-top: auto;
}
